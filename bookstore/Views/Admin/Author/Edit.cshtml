@model Author
@{
    ViewData["Title"] = "Sửa tác giả";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<a href="/Admin/Author" class="btn btn-outline-secondary mb-3"><i class="fas fa-arrow-left me-1"></i>Quay lại</a>
<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <h4 class="fw-bold mb-4">Sửa tác giả</h4>
        <form action="/Admin/Author/Edit/@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="mb-3" style="max-width: 400px;">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3" style="max-width: 400px;">
                <label asp-for="Bio" class="form-label"></label>
                <textarea asp-for="Bio" class="form-control" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Cập nhật</button>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
