@model List<Author>
@{
    ViewData["Title"] = "Quản lý tác giả";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Quản lý tác giả</h4>
    <a href="/Admin/Author/Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Thêm tác giả</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>#</th><th>Tên tác giả</th><th>Tiểu sử</th><th>Số sách</th><th>Thao tác</th></tr></thead>
            <tbody>
                @foreach (var author in Model)
                {
                    <tr>
                        <td>@author.Id</td>
                        <td class="fw-semibold">@author.Name</td>
                        <td class="text-muted">@(author.Bio?.Length > 50 ? author.Bio.Substring(0, 50) + "..." : author.Bio)</td>
                        <td><span class="badge bg-info">@(author.Books?.Count ?? 0)</span></td>
                        <td>
                            <a href="/Admin/Author/Edit/@author.Id" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                            <form action="/Admin/Author/Delete/@author.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
