@model Publisher
@{
    ViewData["Title"] = "Thêm nhà xuất bản";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<a href="/Admin/Publisher" class="btn btn-outline-secondary mb-3"><i class="fas fa-arrow-left me-1"></i>Quay lại</a>
<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <h4 class="fw-bold mb-4">Thêm nhà xuất bản</h4>
        <form action="/Admin/Publisher/Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3" style="max-width: 400px;">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Lưu</button>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
