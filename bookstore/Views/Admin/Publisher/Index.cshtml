@model List<Publisher>
@{
    ViewData["Title"] = "Quản lý nhà xuất bản";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Quản lý nhà xuất bản</h4>
    <a href="/Admin/Publisher/Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Thêm NXB</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>#</th><th>Tên NXB</th><th>Số sách</th><th>Thao tác</th></tr></thead>
            <tbody>
                @foreach (var pub in Model)
                {
                    <tr>
                        <td>@pub.Id</td>
                        <td class="fw-semibold">@pub.Name</td>
                        <td><span class="badge bg-info">@(pub.Books?.Count ?? 0)</span></td>
                        <td>
                            <a href="/Admin/Publisher/Edit/@pub.Id" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                            <form action="/Admin/Publisher/Delete/@pub.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
