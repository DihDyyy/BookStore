@model List<Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var currentStatus = ViewBag.CurrentStatus as string;
}

<h4 class="fw-bold mb-4">Quản lý đơn hàng</h4>

<!-- Status Filter -->
<div class="mb-4">
    <a href="/Admin/Order" class="btn btn-sm @(currentStatus == null ? "btn-primary" : "btn-outline-primary") me-1">Tất cả</a>
    <a href="/Admin/Order?status=Chờ xử lý" class="btn btn-sm @(currentStatus == "Chờ xử lý" ? "btn-warning" : "btn-outline-warning") me-1">Chờ xử lý</a>
    <a href="/Admin/Order?status=Đang giao" class="btn btn-sm @(currentStatus == "Đang giao" ? "btn-info" : "btn-outline-info") me-1">Đang giao</a>
    <a href="/Admin/Order?status=Đã giao" class="btn btn-sm @(currentStatus == "Đã giao" ? "btn-success" : "btn-outline-success") me-1">Đã giao</a>
    <a href="/Admin/Order?status=Đã hủy" class="btn btn-sm @(currentStatus == "Đã hủy" ? "btn-danger" : "btn-outline-danger")">Đã hủy</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>#</th><th>Khách hàng</th><th>SĐT</th><th>Tổng tiền</th><th>Trạng thái</th><th>Ngày đặt</th><th>Thao tác</th></tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    var cls = order.Status switch { "Chờ xử lý" => "bg-warning", "Đang giao" => "bg-info", "Đã giao" => "bg-success", "Đã hủy" => "bg-danger", _ => "bg-secondary" };
                    <tr>
                        <td>@order.Id</td>
                        <td class="fw-semibold">@order.FullName</td>
                        <td>@order.Phone</td>
                        <td class="text-danger fw-bold">@order.TotalPrice.ToString("N0")₫</td>
                        <td><span class="badge @cls">@order.Status</span></td>
                        <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <a href="/Admin/Order/Details/@order.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
