@model Order
@{
    ViewData["Title"] = $"Chi tiết đơn hàng #{Model.Id}";
}

<div class="container py-4">
    <a asp-controller="Order" asp-action="History" class="btn btn-outline-secondary mb-3"><i class="fas fa-arrow-left me-1"></i>Quay lại</a>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold mb-0">Đơn hàng #@Model.Id</h4>
                @{
                    var badgeClass = Model.Status switch { "Chờ xử lý" => "bg-warning", "Đang giao" => "bg-info", "Đã giao" => "bg-success", "Đã hủy" => "bg-danger", _ => "bg-secondary" };
                }
                <span class="badge @badgeClass fs-6">@Model.Status</span>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <p><strong>Người nhận:</strong> @Model.FullName</p>
                    <p><strong>SĐT:</strong> @Model.Phone</p>
                    <p><strong>Địa chỉ:</strong> @Model.Address</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Ngày đặt:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                    @if (!string.IsNullOrEmpty(Model.Note))
                    {
                        <p><strong>Ghi chú:</strong> @Model.Note</p>
                    }
                </div>
            </div>

            <table class="table">
                <thead class="table-light">
                    <tr><th>Sách</th><th class="text-center">SL</th><th class="text-end">Đơn giá</th><th class="text-end">Thành tiền</th></tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderDetails!)
                    {
                        <tr>
                            <td>@item.Book?.Title</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">@item.Price.ToString("N0")₫</td>
                            <td class="text-end fw-bold">@((item.Price * item.Quantity).ToString("N0"))₫</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="fw-bold"><td colspan="3">Tổng cộng:</td><td class="text-end text-danger h5">@Model.TotalPrice.ToString("N0")₫</td></tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
