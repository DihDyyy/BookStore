@model List<Order>
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4"><i class="fas fa-history me-2"></i>Lịch sử đơn hàng</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
            <h5>Bạn chưa có đơn hàng nào</h5>
            <a asp-controller="Book" asp-action="Index" class="btn btn-primary mt-2">Mua sắm ngay</a>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã ĐH</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="fw-bold">#@order.Id</td>
                                <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-danger fw-bold">@order.TotalPrice.ToString("N0")₫</td>
                                <td>
                                    @{
                                        var badgeClass = order.Status switch
                                        {
                                            "Chờ xử lý" => "bg-warning",
                                            "Đang giao" => "bg-info",
                                            "Đã giao" => "bg-success",
                                            "Đã hủy" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@order.Status</span>
                                </td>
                                <td>
                                    <a asp-controller="Order" asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye"></i> Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
