@model CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4"><i class="fas fa-credit-card me-2"></i>Thanh toán</h2>

    <form asp-controller="Order" asp-action="Checkout" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">Thông tin giao hàng</h5>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label"></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label"></label>
                            <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Note" class="form-label"></label>
                            <textarea asp-for="Note" class="form-control" rows="2" placeholder="Ghi chú cho đơn hàng (tùy chọn)"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">Đơn hàng của bạn</h5>

                        @foreach (var item in Model.CartItems)
                        {
                            <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                <div>
                                    <strong>@item.Title</strong>
                                    <br /><small class="text-muted">x@item.Quantity</small>
                                </div>
                                <span class="fw-bold">@item.Total.ToString("N0")₫</span>
                            </div>
                        }

                        <div class="d-flex justify-content-between mt-3 pt-3 border-top">
                            <span class="h5 mb-0">Tổng cộng:</span>
                            <span class="h4 mb-0 text-danger fw-bold">@Model.TotalPrice.ToString("N0")₫</span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 mt-4">
                            <i class="fas fa-check me-2"></i>Đặt hàng
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
