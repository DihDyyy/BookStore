@model List<Wishlist>
@{
    ViewData["Title"] = "Sách yêu thích";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4"><i class="fas fa-heart text-danger me-2"></i>Sách yêu thích</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-heart fa-4x text-muted mb-3"></i>
            <h5>Chưa có sách yêu thích</h5>
            <a asp-controller="Book" asp-action="Index" class="btn btn-primary mt-2">Khám phá sách</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card book-card border-0 shadow-sm h-100">
                        <a asp-controller="Book" asp-action="Details" asp-route-id="@item.BookId" class="text-decoration-none">
                            <div class="book-img-wrapper">
                                @if (!string.IsNullOrEmpty(item.Book?.Image))
                                {
                                    <img src="~/images/books/@item.Book.Image" class="card-img-top book-img" alt="@item.Book?.Title" />
                                }
                                else
                                {
                                    <div class="card-img-top book-img d-flex align-items-center justify-content-center bg-light">
                                        <i class="fas fa-book fa-3x text-muted"></i>
                                    </div>
                                }
                            </div>
                        </a>
                        <div class="card-body d-flex flex-column">
                            <small class="text-muted">@item.Book?.Author?.Name</small>
                            <h6 class="fw-bold">@item.Book?.Title</h6>
                            <span class="text-danger fw-bold mb-2">@item.Book?.Price.ToString("N0")₫</span>
                            <div class="mt-auto d-flex gap-2">
                                <form asp-controller="Cart" asp-action="Add" method="post" class="flex-fill">
                                    <input type="hidden" name="bookId" value="@item.BookId" />
                                    <button type="submit" class="btn btn-primary btn-sm w-100"><i class="fas fa-cart-plus"></i></button>
                                </form>
                                <form asp-controller="Wishlist" asp-action="Toggle" method="post">
                                    <input type="hidden" name="bookId" value="@item.BookId" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm"><i class="fas fa-heart-broken"></i></button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
