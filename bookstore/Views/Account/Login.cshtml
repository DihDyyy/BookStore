@model bookstore.Models.ViewModels.LoginViewModel
@{ ViewData["Title"] = "Đăng nhập"; Layout = null; }
<!DOCTYPE html>
<html lang="vi"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Đăng nhập - BookStore</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/site.css" /></head>
<body>
<div class="auth-wrapper">
    <div class="auth-card">
        <div class="text-center mb-4"><a href="/" style="font-size:1.5rem;font-weight:800;color:var(--primary)"><i class="fas fa-book-open me-2"></i>BookStore</a></div>
        <h2 class="text-center">Đăng nhập</h2>
        <p class="subtitle text-center">Chào mừng bạn quay trở lại!</p>
        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3" style="font-size:.85rem"></div>
            <div class="mb-3"><label class="form-label fw-semibold">Email</label><div class="input-group"><span class="input-group-text" style="border-radius:8px 0 0 8px;border:2px solid var(--gray-light);border-right:none;background:#f8fafc"><i class="fas fa-envelope" style="color:var(--gray)"></i></span><input asp-for="Email" class="form-control" style="border-left:none;border-radius:0 8px 8px 0" placeholder="email@example.com" /></div><span asp-validation-for="Email" class="text-danger" style="font-size:.8rem"></span></div>
            <div class="mb-3"><label class="form-label fw-semibold">Mật khẩu</label><div class="input-group"><span class="input-group-text" style="border-radius:8px 0 0 8px;border:2px solid var(--gray-light);border-right:none;background:#f8fafc"><i class="fas fa-lock" style="color:var(--gray)"></i></span><input asp-for="Password" class="form-control" style="border-left:none;border-radius:0 8px 8px 0" placeholder="••••••" /></div><span asp-validation-for="Password" class="text-danger" style="font-size:.8rem"></span></div>
            <div class="d-flex justify-content-between align-items-center mb-4"><div class="form-check"><input asp-for="RememberMe" class="form-check-input" /><label class="form-check-label" style="font-size:.85rem">Ghi nhớ</label></div><a href="/Account/ForgotPassword" style="font-size:.85rem;color:var(--primary)">Quên mật khẩu?</a></div>
            <button type="submit" class="btn btn-primary-custom w-100 py-2" style="font-size:1rem">Đăng nhập</button>
        </form>
        <p class="text-center mt-4" style="font-size:.9rem;color:var(--gray)">Chưa có tài khoản? <a href="/Account/Register" style="color:var(--primary);font-weight:600">Đăng ký ngay</a></p>
    </div>
</div>
</body></html>
