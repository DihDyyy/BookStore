@model bookstore.Models.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Đăng ký"; Layout = null; }
<!DOCTYPE html>
<html lang="vi"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Đăng ký - BookStore</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/site.css" /></head>
<body>
<div class="auth-wrapper">
    <div class="auth-card">
        <div class="text-center mb-4"><a href="/" style="font-size:1.5rem;font-weight:800;color:var(--primary)"><i class="fas fa-book-open me-2"></i>BookStore</a></div>
        <h2 class="text-center">Đăng ký</h2>
        <p class="subtitle text-center">Tạo tài khoản để mua sách</p>
        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3" style="font-size:.85rem"></div>
            <div class="mb-3"><label class="form-label fw-semibold">Họ tên</label><input asp-for="Name" class="form-control" placeholder="Nguyễn Văn A" /><span asp-validation-for="Name" class="text-danger" style="font-size:.8rem"></span></div>
            <div class="mb-3"><label class="form-label fw-semibold">Email</label><input asp-for="Email" class="form-control" placeholder="email@example.com" /><span asp-validation-for="Email" class="text-danger" style="font-size:.8rem"></span></div>
            <div class="mb-3"><label class="form-label fw-semibold">Số điện thoại</label><input asp-for="Phone" class="form-control" placeholder="0901234567" /><span asp-validation-for="Phone" class="text-danger" style="font-size:.8rem"></span></div>
            <div class="mb-3"><label class="form-label fw-semibold">Mật khẩu</label><input asp-for="Password" class="form-control" placeholder="Tối thiểu 6 ký tự" /><span asp-validation-for="Password" class="text-danger" style="font-size:.8rem"></span></div>
            <div class="mb-4"><label class="form-label fw-semibold">Xác nhận mật khẩu</label><input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" /><span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:.8rem"></span></div>
            <button type="submit" class="btn btn-primary-custom w-100 py-2" style="font-size:1rem">Đăng ký</button>
        </form>
        <p class="text-center mt-4" style="font-size:.9rem;color:var(--gray)">Đã có tài khoản? <a href="/Account/Login" style="color:var(--primary);font-weight:600">Đăng nhập</a></p>
    </div>
</div>
</body></html>
