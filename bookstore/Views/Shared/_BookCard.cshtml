@model Book

<div class="card book-card border-0 shadow-sm h-100">
    <a asp-controller="Book" asp-action="Details" asp-route-id="@Model.Id" class="text-decoration-none">
        <div class="book-img-wrapper">
            @if (!string.IsNullOrEmpty(Model.Image))
            {
                <img src="~/images/books/@Model.Image" class="card-img-top book-img" alt="@Model.Title" />
            }
            else
            {
                <div class="card-img-top book-img d-flex align-items-center justify-content-center bg-light">
                    <i class="fas fa-book fa-3x text-muted"></i>
                </div>
            }
            @if (Model.Stock <= 5 && Model.Stock > 0)
            {
                <span class="badge bg-warning position-absolute top-0 end-0 m-2">Sắp hết</span>
            }
            @if (Model.Stock == 0)
            {
                <span class="badge bg-danger position-absolute top-0 end-0 m-2">Hết hàng</span>
            }
        </div>
    </a>
    <div class="card-body d-flex flex-column">
        <small class="text-muted mb-1">@Model.Author?.Name</small>
        <h6 class="card-title fw-bold mb-2">
            <a asp-controller="Book" asp-action="Details" asp-route-id="@Model.Id" class="text-decoration-none text-dark book-title">
                @Model.Title
            </a>
        </h6>
        <div class="mt-auto">
            <span class="h5 text-danger fw-bold">@Model.Price.ToString("N0")₫</span>
        </div>
        <form asp-controller="Cart" asp-action="Add" method="post" class="mt-2">
            <input type="hidden" name="bookId" value="@Model.Id" />
            <input type="hidden" name="quantity" value="1" />
            <button type="submit" class="btn btn-primary btn-sm w-100" @(Model.Stock == 0 ? "disabled" : "")>
                <i class="fas fa-cart-plus me-1"></i>Thêm giỏ hàng
            </button>
        </form>
    </div>
</div>
