@model bookstore.Models.Book
@{
    var avgRating = Model.Reviews != null && Model.Reviews.Any() ? Model.Reviews.Average(r => r.Rating) : 0;
    var reviewCount = Model.Reviews?.Count ?? 0;
}
<div class="book-card">
    <div class="card-img-wrapper">
        @if (Model.IsOnSale)
        {
            <span class="badge-sale">-@Model.DiscountPercent%</span>
        }
        @if (Model.IsFeatured && !Model.IsOnSale)
        {
            <span class="badge-featured"><i class="fas fa-star me-1"></i>Nổi bật</span>
        }
        @if (!string.IsNullOrEmpty(Model.Image))
        {
            <img src="/images/books/@Model.Image" alt="@Model.Title" loading="lazy" />
        }
        else
        {
            <i class="fas fa-book no-image"></i>
        }
        <div class="card-actions">
            <button class="btn btn-light btn-sm" onclick="addToCart(@Model.Id)" title="Thêm giỏ hàng"><i class="fas fa-cart-plus"></i></button>
            <a href="/Book/Details/@Model.Id" class="btn btn-primary-custom btn-sm">Chi tiết</a>
        </div>
    </div>
    <div class="card-body">
        @if (Model.Category != null)
        {
            <span class="book-category">@Model.Category.Name</span>
        }
        <a href="/Book/Details/@Model.Id" class="book-title">@Model.Title</a>
        @if (Model.Author != null)
        {
            <span class="book-author"><i class="fas fa-pen-fancy me-1"></i>@Model.Author.Name</span>
        }
        @if (reviewCount > 0)
        {
            <div class="stars">
                @for (int i = 1; i <= 5; i++)
                {
                    <i class="fas fa-star @(i <= Math.Round(avgRating) ? "" : "empty")"></i>
                }
                <small class="ms-1" style="color:var(--gray)">(@reviewCount)</small>
            </div>
        }
        <div class="price-wrapper">
            @if (Model.IsOnSale)
            {
                <span class="price">@Model.SalePrice?.ToString("N0")đ</span>
                <span class="price-original">@Model.Price.ToString("N0")đ</span>
            }
            else
            {
                <span class="price">@Model.Price.ToString("N0")đ</span>
            }
        </div>
    </div>
</div>
