@model HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Banner -->
<section class="hero-banner">
    <div class="container">
        <div class="row align-items-center min-vh-50">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold text-white mb-3">Khám Phá Thế Giới<br /><span class="text-warning">Qua Từng Trang Sách</span></h1>
                <p class="lead text-white-50 mb-4">Hàng ngàn đầu sách từ nhiều thể loại đang chờ bạn khám phá. Mua sách online dễ dàng, giao hàng nhanh chóng.</p>
                <a asp-controller="Book" asp-action="Index" class="btn btn-warning btn-lg px-4 me-2">
                    <i class="fas fa-book-reader me-2"></i>Khám phá ngay
                </a>
            </div>
            <div class="col-lg-6 text-center">
                <i class="fas fa-books" style="font-size: 200px; color: rgba(255,255,255,0.1);"></i>
            </div>
        </div>
    </div>
</section>

<!-- Categories -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Danh Mục Sách</h2>
            <p class="text-muted">Khám phá sách theo thể loại yêu thích</p>
        </div>
        <div class="row g-3">
            @foreach (var cat in Model.Categories)
            {
                <div class="col-6 col-md-3">
                    <a asp-controller="Book" asp-action="Index" asp-route-categoryId="@cat.Id" class="text-decoration-none">
                        <div class="card category-card border-0 shadow-sm h-100 text-center p-4">
                            <i class="fas fa-book-open fa-2x text-primary mb-3"></i>
                            <h6 class="fw-bold mb-1">@cat.Name</h6>
                            <small class="text-muted">@(cat.Books?.Count ?? 0) sách</small>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<!-- New Books -->
<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-0">Sách Mới</h2>
                <p class="text-muted mb-0">Những đầu sách mới nhất</p>
            </div>
            <a asp-controller="Book" asp-action="Index" asp-route-sortBy="newest" class="btn btn-outline-primary">
                Xem tất cả <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>
        <div class="row g-4">
            @foreach (var book in Model.NewBooks)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <partial name="_BookCard" model="book" />
                </div>
            }
        </div>
    </div>
</section>

<!-- Best Sellers -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-0"><i class="fas fa-fire text-danger me-2"></i>Sách Bán Chạy</h2>
                <p class="text-muted mb-0">Được yêu thích nhất</p>
            </div>
            <a asp-controller="Book" asp-action="Index" class="btn btn-outline-primary">
                Xem tất cả <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>
        <div class="row g-4">
            @foreach (var book in Model.BestSellers)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <partial name="_BookCard" model="book" />
                </div>
            }
        </div>
    </div>
</section>
