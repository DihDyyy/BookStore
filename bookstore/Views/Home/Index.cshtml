@model bookstore.Models.ViewModels.HomeViewModel
@{ ViewData["Title"] = "Trang chủ"; }

<!-- Banner Slider -->
<div class="hero-banner">
    @foreach (var banner in Model.Banners)
    {
        <div class="banner-slide">
            <div class="banner-content">
                <h1>@banner.Title</h1>
                <p>@banner.Subtitle</p>
                <a href="@(banner.LinkUrl ?? "/Book")" class="btn btn-light btn-lg" style="border-radius:50px;font-weight:600;padding:10px 30px">
                    Khám phá ngay <i class="fas fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    }
    @if (Model.Banners.Count > 1)
    {
        <div class="banner-dots">
            @for (int i = 0; i < Model.Banners.Count; i++)
            {
                <div class="banner-dot @(i == 0 ? "active" : "")"></div>
            }
        </div>
    }
</div>

<div class="container py-5">
    <!-- Flash Sale -->
    @if (Model.FlashSaleBooks.Any())
    {
        <div class="flash-sale-section fade-up">
            <div class="section-header">
                <h2><i class="fas fa-bolt me-2" style="color:var(--danger)"></i>Flash Sale</h2>
            </div>
            @{
                var saleEnd = Model.FlashSaleBooks.Min(b => b.SaleEndDate);
            }
            <div class="countdown" data-countdown="@saleEnd?.ToString("yyyy-MM-ddTHH:mm:ss")"></div>
            <div class="row g-3">
                @foreach (var book in Model.FlashSaleBooks.Take(4))
                {
                    <div class="col-6 col-md-3">@await Html.PartialAsync("_BookCard", book)</div>
                }
            </div>
        </div>
    }

    <!-- Categories -->
    <section class="my-5 fade-up">
        <div class="section-header"><h2>Danh mục sách</h2><p>Khám phá kho sách đa dạng theo thể loại</p></div>
        <div class="row g-3">
            @foreach (var cat in Model.Categories)
            {
                <div class="col-6 col-md-3 col-lg">
                    <a href="/Book?categoryId=@cat.Id" class="category-card d-block">
                        <div class="icon"><i class="fas @(cat.Icon ?? "fa-book")"></i></div>
                        <h6>@cat.Name</h6>
                        <small>@(cat.Books?.Count ?? 0) sách</small>
                    </a>
                </div>
            }
        </div>
    </section>

    <!-- Featured Books -->
    @if (Model.FeaturedBooks.Any())
    {
        <section class="my-5 fade-up">
            <div class="section-header"><h2>Sách nổi bật</h2><p>Được yêu thích nhất bởi độc giả</p></div>
            <div class="row g-3">
                @foreach (var book in Model.FeaturedBooks.Take(4))
                {
                    <div class="col-6 col-md-3">@await Html.PartialAsync("_BookCard", book)</div>
                }
            </div>
        </section>
    }

    <!-- New Books -->
    <section class="my-5 fade-up">
        <div class="section-header"><h2>Sách mới nhất</h2><p>Cập nhật mỗi ngày</p></div>
        <div class="row g-3">
            @foreach (var book in Model.NewBooks.Take(8))
            {
                <div class="col-6 col-md-3">@await Html.PartialAsync("_BookCard", book)</div>
            }
        </div>
        <div class="text-center mt-4"><a href="/Book?sortBy=newest" class="btn btn-outline-custom">Xem tất cả <i class="fas fa-arrow-right ms-1"></i></a></div>
    </section>

    <!-- Best Sellers -->
    <section class="my-5 fade-up">
        <div class="section-header"><h2>Sách bán chạy</h2><p>Top sách được mua nhiều nhất</p></div>
        <div class="row g-3">
            @foreach (var book in Model.BestSellers.Take(8))
            {
                <div class="col-6 col-md-3">@await Html.PartialAsync("_BookCard", book)</div>
            }
        </div>
    </section>
</div>
