@model Book
@{
    ViewData["Title"] = Model.Title;
    var relatedBooks = ViewBag.RelatedBooks as List<Book>;
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-controller="Book" asp-action="Index">Sách</a></li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <div class="row g-4">
                <!-- Book Image -->
                <div class="col-md-5 text-center">
                    <div class="book-detail-img-wrapper">
                        @if (!string.IsNullOrEmpty(Model.Image))
                        {
                            <img src="~/images/books/@Model.Image" class="img-fluid rounded shadow" alt="@Model.Title" style="max-height: 500px;" />
                        }
                        else
                        {
                            <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 400px;">
                                <i class="fas fa-book fa-5x text-muted"></i>
                            </div>
                        }
                    </div>
                </div>

                <!-- Book Details -->
                <div class="col-md-7">
                    <span class="badge bg-primary mb-2">@Model.Category?.Name</span>
                    <h2 class="fw-bold mb-2">@Model.Title</h2>
                    <p class="text-muted mb-3">
                        <i class="fas fa-pen-fancy me-1"></i>Tác giả: <strong>@Model.Author?.Name</strong>
                    </p>

                    <h3 class="text-danger fw-bold mb-4">@Model.Price.ToString("N0")₫</h3>

                    <table class="table table-borderless">
                        <tr>
                            <td class="text-muted" style="width: 150px;"><i class="fas fa-building me-2"></i>Nhà xuất bản</td>
                            <td class="fw-semibold">@Model.Publisher?.Name</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i class="fas fa-calendar me-2"></i>Năm xuất bản</td>
                            <td class="fw-semibold">@(Model.PublicationYear?.ToString() ?? "N/A")</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i class="fas fa-boxes me-2"></i>Còn lại</td>
                            <td>
                                @if (Model.Stock > 10)
                                {
                                    <span class="badge bg-success">Còn hàng (@Model.Stock)</span>
                                }
                                else if (Model.Stock > 0)
                                {
                                    <span class="badge bg-warning">Sắp hết (@Model.Stock)</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Hết hàng</span>
                                }
                            </td>
                        </tr>
                    </table>

                    @if (Model.Stock > 0)
                    {
                        <form asp-controller="Cart" asp-action="Add" method="post" class="mt-3">
                            <input type="hidden" name="bookId" value="@Model.Id" />
                            <div class="d-flex align-items-center gap-3">
                                <div class="input-group" style="width: 140px;">
                                    <button type="button" class="btn btn-outline-secondary" onclick="changeQty(-1)">−</button>
                                    <input type="number" name="quantity" id="quantity" value="1" min="1" max="@Model.Stock" class="form-control text-center" />
                                    <button type="button" class="btn btn-outline-secondary" onclick="changeQty(1)">+</button>
                                </div>
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-cart-plus me-2"></i>Thêm vào giỏ hàng
                                </button>
                            </div>
                        </form>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Wishlist" asp-action="Toggle" method="post" class="mt-3">
                            <input type="hidden" name="bookId" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="fas fa-heart me-1"></i>Thêm vào yêu thích
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Description -->
    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-3"><i class="fas fa-info-circle me-2"></i>Mô tả sách</h4>
                <p class="text-muted lh-lg">@Model.Description</p>
            </div>
        </div>
    }

    <!-- Related Books -->
    @if (relatedBooks != null && relatedBooks.Any())
    {
        <div class="mt-5">
            <h4 class="fw-bold mb-3">Sách cùng thể loại</h4>
            <div class="row g-4">
                @foreach (var book in relatedBooks)
                {
                    <div class="col-6 col-md-3">
                        <partial name="_BookCard" model="book" />
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function changeQty(delta) {
            var input = document.getElementById('quantity');
            var val = parseInt(input.value) + delta;
            if (val < 1) val = 1;
            if (val > parseInt(input.max)) val = parseInt(input.max);
            input.value = val;
        }
    </script>
}
