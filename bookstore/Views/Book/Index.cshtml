@model BookFilterViewModel
@{
    ViewData["Title"] = "Danh sách sách";
}

<div class="container py-4">
    <div class="row">
        <!-- Sidebar Filters -->
        <div class="col-lg-3 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold mb-3"><i class="fas fa-filter me-2"></i>Bộ lọc</h5>
                    <form asp-controller="Book" asp-action="Index" method="get">
                        <!-- Search -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tìm kiếm</label>
                            <input type="text" name="searchQuery" value="@Model.SearchQuery" class="form-control" placeholder="Tên sách, tác giả..." />
                        </div>

                        <!-- Category -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Danh mục</label>
                            <select name="categoryId" class="form-select">
                                <option value="">-- Tất cả --</option>
                                @foreach (var cat in Model.Categories)
                                {
                                    <option value="@cat.Id" selected="@(Model.CategoryId == cat.Id)">@cat.Name</option>
                                }
                            </select>
                        </div>

                        <!-- Author -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tác giả</label>
                            <select name="authorId" class="form-select">
                                <option value="">-- Tất cả --</option>
                                @foreach (var author in Model.Authors)
                                {
                                    <option value="@author.Id" selected="@(Model.AuthorId == author.Id)">@author.Name</option>
                                }
                            </select>
                        </div>

                        <!-- Publisher -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nhà xuất bản</label>
                            <select name="publisherId" class="form-select">
                                <option value="">-- Tất cả --</option>
                                @foreach (var pub in Model.Publishers)
                                {
                                    <option value="@pub.Id" selected="@(Model.PublisherId == pub.Id)">@pub.Name</option>
                                }
                            </select>
                        </div>

                        <!-- Price Range -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Giá (VNĐ)</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input type="number" name="minPrice" value="@Model.MinPrice" class="form-control" placeholder="Từ" />
                                </div>
                                <div class="col-6">
                                    <input type="number" name="maxPrice" value="@Model.MaxPrice" class="form-control" placeholder="Đến" />
                                </div>
                            </div>
                        </div>

                        <!-- Sort -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Sắp xếp</label>
                            <select name="sortBy" class="form-select">
                                <option value="newest" selected="@(Model.SortBy == "newest")">Mới nhất</option>
                                <option value="price_asc" selected="@(Model.SortBy == "price_asc")">Giá tăng dần</option>
                                <option value="price_desc" selected="@(Model.SortBy == "price_desc")">Giá giảm dần</option>
                                <option value="name_asc" selected="@(Model.SortBy == "name_asc")">Tên A-Z</option>
                                <option value="name_desc" selected="@(Model.SortBy == "name_desc")">Tên Z-A</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search me-2"></i>Lọc sách</button>
                        <a asp-controller="Book" asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">Xóa bộ lọc</a>
                    </form>
                </div>
            </div>
        </div>

        <!-- Book Grid -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <p class="text-muted mb-0">Hiển thị <strong>@Model.Books.Count</strong> / <strong>@Model.TotalItems</strong> sách</p>
            </div>

            @if (!Model.Books.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-search fa-3x text-muted mb-3"></i>
                    <h5>Không tìm thấy sách</h5>
                    <p class="text-muted">Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm</p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var book in Model.Books)
                    {
                        <div class="col-6 col-md-4">
                            <partial name="_BookCard" model="book" />
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-controller="Book" asp-action="Index"
                                   asp-route-page="@(Model.CurrentPage - 1)"
                                   asp-route-categoryId="@Model.CategoryId"
                                   asp-route-authorId="@Model.AuthorId"
                                   asp-route-publisherId="@Model.PublisherId"
                                   asp-route-minPrice="@Model.MinPrice"
                                   asp-route-maxPrice="@Model.MaxPrice"
                                   asp-route-searchQuery="@Model.SearchQuery"
                                   asp-route-sortBy="@Model.SortBy">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-controller="Book" asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-categoryId="@Model.CategoryId"
                                       asp-route-authorId="@Model.AuthorId"
                                       asp-route-publisherId="@Model.PublisherId"
                                       asp-route-minPrice="@Model.MinPrice"
                                       asp-route-maxPrice="@Model.MaxPrice"
                                       asp-route-searchQuery="@Model.SearchQuery"
                                       asp-route-sortBy="@Model.SortBy">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-controller="Book" asp-action="Index"
                                   asp-route-page="@(Model.CurrentPage + 1)"
                                   asp-route-categoryId="@Model.CategoryId"
                                   asp-route-authorId="@Model.AuthorId"
                                   asp-route-publisherId="@Model.PublisherId"
                                   asp-route-minPrice="@Model.MinPrice"
                                   asp-route-maxPrice="@Model.MaxPrice"
                                   asp-route-searchQuery="@Model.SearchQuery"
                                   asp-route-sortBy="@Model.SortBy">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>
